# ══════════════════════════════════════════════════════════════════════════════
# Norvel Writer — LLM Configuration  (.env.example)
# ══════════════════════════════════════════════════════════════════════════════
#
# QUICK START
#   1. Rename this file to .env  (same folder as run.bat)
#   2. Install Ollama: https://ollama.com/download
#   3. Pull the two required models (run in a terminal):
#        ollama pull gpt-oss:120b-cloud
#        ollama pull nomic-embed-text
#   4. Launch the app — done.  No other changes needed.
#
# This file is pre-configured for gpt-oss:120b-cloud (Ollama's best cloud
# writing model, 128K context, no local GPU required).  All settings below
# are already optimised — rename and run.
#
# To switch provider or model, see the alternative sections at the bottom,
# or use Settings → LLM Config inside the app to edit .env directly.
#
# ══════════════════════════════════════════════════════════════════════════════


# ── Active provider ────────────────────────────────────────────────────────
LLM_PROVIDER=ollama
EMBEDDINGS_PROVIDER=ollama

# ── Context retrieval mode ─────────────────────────────────────────────────
#
# CONTEXT_MODE controls how your documents (codex, notes, etc.) are sent to
# the AI when it writes.
#
#   full  — Send ALL document text directly to the model in every call.
#           No embedding search, no chunk selection.  The model sees your
#           entire world-bible, all notes, and all style samples at once.
#           Best for cloud / large-context models (≥ 32 K tokens).
#           Auto-selected when OLLAMA_CHAT_MODEL ends in "-cloud".
#
#   rag   — Vector-similarity search selects the most relevant chunks per
#           call and injects only those.  Essential for local models with
#           small context windows (≤ 8 K tokens).  Requires Ollama embedding
#           model (nomic-embed-text) and ChromaDB to be running.
#
# Leave blank to auto-detect (cloud model name → full; local → rag).
#
CONTEXT_MODE=full


# ══════════════════════════════════════════════════════════════════════════════
# OLLAMA  ✓ ACTIVE
# ══════════════════════════════════════════════════════════════════════════════
#
# HOW OLLAMA CLOUD WORKS WITH THIS APP
# ─────────────────────────────────────────────────────────────────────────────
# • Embeddings run locally via nomic-embed-text on YOUR machine.
#   Codex/notes are chunked and stored locally in ChromaDB as usual.
# • At generation time the app selects the most relevant chunks (RAG) and
#   sends those chunks to Ollama's cloud servers — not your raw files.
# • With the 128K settings below, ~48 000 tokens of codex fit per call,
#   covering the entire world-bible for most novels.
# • The response streams back into the editor exactly like a local model.
#
# PRIVACY NOTE
#   Selected context chunks (codex excerpts, beats, notes) ARE sent to
#   Ollama's servers for inference.  Raw uploaded files stay on your disk.
#   For full local privacy, switch to a local model (see presets below).
#
# AVAILABLE CLOUD MODELS (run: ollama pull <model>)
#   gpt-oss:120b-cloud        GPT OSS  120B  128K ctx  best writing  ← active
#   gpt-oss:20b-cloud         GPT OSS   20B  128K ctx  lighter / faster
#   deepseek-v3.1:671b-cloud  DeepSeek 671B  128K ctx  highest param count
#   qwen3-vl:235b-cloud       Qwen3 VL 235B  128K ctx  vision capable
#   minimax-m2:cloud          MiniMax M2     128K ctx
#
# ── Connection ────────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_CHAT_MODEL=gpt-oss:120b-cloud
OLLAMA_EMBED_MODEL=nomic-embed-text
# OLLAMA_VISION_MODEL=llava:7b


# ── Sampling parameters (optimised for gpt-oss:120b-cloud) ────────────────────
#
# TEMPERATURE  0.8 — balanced creativity + coherence for a large model
# TOP_P        0.95 — nucleus sampling; standard for GPT-family
# TOP_K        blank — GPT-family models have rich token distributions;
#              capping top-K kills vocabulary diversity and flattens prose
# NUM_CTX      131072 = exactly 128K, the model's full context window
# NUM_PREDICT  8192 ≈ 6 100 words per call (auto-raised when you set a
#              higher Target Length in Draft AI)
# REPEAT_LAST_N  64 — Ollama default; irrelevant when REPEAT_PENALTY=1.0
# REPEAT_PENALTY 1.0 — OFF for GPT-family; the model's training handles
#              repetition internally. Values >1.0 penalise intentional
#              stylistic repetition, rhythm, and natural pronoun reuse.
#
OLLAMA_TEMPERATURE=0.8
OLLAMA_TOP_P=0.95
OLLAMA_TOP_K=
OLLAMA_NUM_CTX=131072
OLLAMA_NUM_PREDICT=8192
OLLAMA_REPEAT_LAST_N=64
OLLAMA_REPEAT_PENALTY=1.0


# ── Context budgets (optimised for 128K — Tier 3) ─────────────────────────────
#
# These control how many tokens of each category are included in every prompt.
# Formula:  input_budget = NUM_CTX − NUM_PREDICT − 1000 overhead = 121 880
#           RAG_BUDGET   ≈ input_budget × 0.40  =  48 000
#           STYLE_BUDGET ≈ input_budget × 0.15  =  18 000
#           TEXT_BUDGET  ≈ input_budget × 0.35  =  42 000
#           (remaining 10 % → system prompt, beats, persona, editor/QA notes)
#
# ┌──────────────────────────────────────────────────────────────────────────┐
# │  CLOUD MODEL TIERS                                                        │
# ├──────────────────┬──────────┬─────────────┬──────────────────────────────┤
# │ Tier             │ NUM_CTX  │ NUM_PREDICT │ RAG / STYLE / TEXT budgets   │
# ├──────────────────┼──────────┼─────────────┼──────────────────────────────┤
# │ Tier 1 — 32K     │  32 768  │    8 192    │  9 000 /  3 500 /  8 000     │
# │ Tier 2 — 64K     │  65 536  │    8 192    │ 22 000 /  8 000 / 19 000     │
# │ Tier 3 — 128K ✓  │ 131 072  │    8 192    │ 48 000 / 18 000 / 42 000     │
# └──────────────────┴──────────┴─────────────┴──────────────────────────────┘
#
CONTEXT_RAG_BUDGET=48000
CONTEXT_STYLE_BUDGET=18000
CONTEXT_TEXT_BUDGET=42000

# CONTEXT_CODEX_THRESHOLD  cosine distance filter applied to codex chunks in
#   "Write from Beats" mode.  Keeps unrelated world-building out of the prompt.
#   0.35 = strict (named entities only)  |  0.50 = balanced  |  1.00 = off
CONTEXT_CODEX_THRESHOLD=0.50


# ══════════════════════════════════════════════════════════════════════════════
# ALTERNATIVE MODEL PRESETS
# Uncomment a block to switch models.  Comment out the active block above.
# ══════════════════════════════════════════════════════════════════════════════

# ── Ollama cloud — lighter model (faster, lower cost) ─────────────────────────
# OLLAMA_CHAT_MODEL=gpt-oss:20b-cloud
# OLLAMA_TEMPERATURE=0.8
# OLLAMA_TOP_P=0.95
# OLLAMA_TOP_K=
# OLLAMA_NUM_CTX=131072
# OLLAMA_NUM_PREDICT=8192
# OLLAMA_REPEAT_LAST_N=64
# OLLAMA_REPEAT_PENALTY=1.0
# CONTEXT_RAG_BUDGET=48000
# CONTEXT_STYLE_BUDGET=18000
# CONTEXT_TEXT_BUDGET=42000

# ── Local — Gemma 4 e2b (8 GB VRAM, 128K ctx) ────────────────────────────────
# ollama pull gemma4:e2b
# OLLAMA_CHAT_MODEL=gemma4:e2b
# OLLAMA_TEMPERATURE=1.0
# OLLAMA_TOP_P=0.95
# OLLAMA_TOP_K=64
# OLLAMA_NUM_CTX=32768
# OLLAMA_NUM_PREDICT=8192
# OLLAMA_REPEAT_LAST_N=512
# OLLAMA_REPEAT_PENALTY=1.10
# CONTEXT_MODE=full
# CONTEXT_RAG_BUDGET=9000
# CONTEXT_STYLE_BUDGET=3500
# CONTEXT_TEXT_BUDGET=8000

# ── Local — Gemma 3 12B (12 GB VRAM, 8K ctx) ─────────────────────────────────
# ollama pull gemma3:12b
# OLLAMA_CHAT_MODEL=gemma3:12b
# OLLAMA_TEMPERATURE=0.7
# OLLAMA_TOP_P=0.95
# OLLAMA_TOP_K=
# OLLAMA_NUM_CTX=8192
# OLLAMA_NUM_PREDICT=4096
# OLLAMA_REPEAT_LAST_N=512
# OLLAMA_REPEAT_PENALTY=1.10
# CONTEXT_MODE=rag
# CONTEXT_RAG_BUDGET=3500
# CONTEXT_STYLE_BUDGET=1500
# CONTEXT_TEXT_BUDGET=3000

# ── Local — Gemma 3 4B (4 GB VRAM, 8K ctx — minimum spec) ───────────────────
# ollama pull gemma3:4b
# OLLAMA_CHAT_MODEL=gemma3:4b
# OLLAMA_TEMPERATURE=0.7
# OLLAMA_TOP_P=
# OLLAMA_TOP_K=
# OLLAMA_NUM_CTX=8192
# OLLAMA_NUM_PREDICT=4096
# OLLAMA_REPEAT_LAST_N=512
# OLLAMA_REPEAT_PENALTY=1.18
# CONTEXT_MODE=rag
# CONTEXT_RAG_BUDGET=3500
# CONTEXT_STYLE_BUDGET=1500
# CONTEXT_TEXT_BUDGET=3000


# ══════════════════════════════════════════════════════════════════════════════
# OPENAI  (alternative — requires API key)
# ══════════════════════════════════════════════════════════════════════════════
# To activate: set LLM_PROVIDER=openai at the top, fill in OPENAI_API_KEY.
# API key: https://platform.openai.com/api-keys
#
# CHAT MODELS
#   gpt-4.1        Most capable, best long-form writing  ← recommended
#   gpt-4.1-mini   Fast & cheap, solid quality
#   gpt-4o         Previous flagship, still excellent
#   o4-mini        Reasoning model — great for QA and editor roles
#
# EMBED MODELS
#   text-embedding-3-small  Fast & cheap  ← recommended
#   text-embedding-3-large  Higher quality, higher cost
#
# OPENAI_BASE_URL  leave blank for official OpenAI endpoint, or set to any
#   OpenAI-compatible URL (LM Studio, vLLM, Together AI, Groq, Fireworks …)
#
# OPENAI_API_KEY=
# OPENAI_CHAT_MODEL=gpt-4.1
# OPENAI_EMBED_MODEL=text-embedding-3-small
# OPENAI_BASE_URL=
# OPENAI_TEMPERATURE=0.8
# OPENAI_MAX_TOKENS=8192


# ══════════════════════════════════════════════════════════════════════════════
# ANTHROPIC  (alternative — requires API key)
# ══════════════════════════════════════════════════════════════════════════════
# To activate: set LLM_PROVIDER=anthropic at the top, fill in ANTHROPIC_API_KEY.
# Keep EMBEDDINGS_PROVIDER=ollama (Anthropic has no embeddings API).
# API key: https://console.anthropic.com
#
# CHAT MODELS
#   claude-3-5-haiku-20241022   Fast & cheap, good for drafts
#   claude-3-7-sonnet-20250219  Balanced — strong creative writing  ← recommended
#   claude-opus-4-5             Most capable, highest cost
#
# ANTHROPIC_API_KEY=
# ANTHROPIC_CHAT_MODEL=claude-3-7-sonnet-20250219
# ANTHROPIC_TEMPERATURE=0.8
# ANTHROPIC_MAX_TOKENS=8192


# ══════════════════════════════════════════════════════════════════════════════
# GOOGLE GEMINI  (alternative — requires API key)
# ══════════════════════════════════════════════════════════════════════════════
# To activate: set LLM_PROVIDER=gemini at the top, fill in GEMINI_API_KEY.
# Keep EMBEDDINGS_PROVIDER=ollama (Gemini embeddings not yet integrated).
# API key: https://aistudio.google.com/app/apikey
#
# CHAT MODELS
#   gemini-2.0-flash   Fast, cheap, excellent quality  ← recommended
#   gemini-2.5-flash   Next-gen flash, improved reasoning
#   gemini-2.5-pro     Most capable Gemini model
#
# GEMINI_API_KEY=
# GEMINI_CHAT_MODEL=gemini-2.0-flash
# GEMINI_TEMPERATURE=0.8
# GEMINI_MAX_TOKENS=8192
