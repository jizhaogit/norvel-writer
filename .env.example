# ══════════════════════════════════════════════════════════════════════════════
# Norvel Writer — LLM Configuration Guide  (.env.example)
# ══════════════════════════════════════════════════════════════════════════════
#
# HOW TO USE
#   1. Copy this file to .env  (same folder as run.bat)
#   2. Uncomment and fill in the section for your chosen provider
#   3. Restart the app — or click "Save & Restart" in Settings → LLM Config
#
# The Settings → LLM Config tab in the app also edits .env directly.
#
# PROVIDERS
#   ollama    — local/cloud models via Ollama  (free, private, or cloud-hosted)
#   openai    — OpenAI API                     (requires API key, sends data online)
#   anthropic — Anthropic Claude API           (requires API key, sends data online)
#   gemini    — Google Gemini API              (requires API key, sends data online)
#
# ══════════════════════════════════════════════════════════════════════════════


# ── Active provider ────────────────────────────────────────────────────────
# Which backend handles chat / writing generation.
# Valid values: ollama | openai | anthropic | gemini
LLM_PROVIDER=ollama

# Which backend handles embeddings (RAG / semantic memory search).
# Only "ollama" and "openai" are supported for embeddings.
# You can mix providers: e.g. LLM_PROVIDER=anthropic + EMBEDDINGS_PROVIDER=ollama
EMBEDDINGS_PROVIDER=ollama


# ══════════════════════════════════════════════════════════════════════════════
# OLLAMA  (local or cloud — https://ollama.com)
# ══════════════════════════════════════════════════════════════════════════════
#
# INSTALL (local)
#   1. Download Ollama: https://ollama.com/download
#   2. Pull the models you want (run in a terminal):
#        ollama pull gpt-oss:120b-cloud   # default — GPT OSS 120B cloud-hosted
#        ollama pull nomic-embed-text     # required for RAG embeddings (~274 MB)
#
# CLOUD MODELS  (hosted by Ollama — no local GPU required)
#   gpt-oss:120b-cloud   GPT OSS  120B params  128K ctx  cloud-hosted   ← default
#   gpt-oss:70b-cloud    GPT OSS   70B params  128K ctx  cloud-hosted
#   gpt-oss:32b-cloud    GPT OSS   32B params  128K ctx  cloud-hosted
#
# LOCAL CHAT MODELS
#   gemma4:e2b      Google Gemma 4  2B eff. params  128K ctx  ~7.2 GB
#   gemma3:12b      Google Gemma 3  12B params         8K ctx  ~7.4 GB
#   llama3.1:8b     Meta            8B params         128K ctx  ~4.7 GB
#   mistral:7b      Mistral AI      7B params          32K ctx  ~4.1 GB
#
# VISION MODELS  (optional — for image description in memory panel)
#   llava:7b           ~4.5 GB
#   llama3.2-vision    ~7.9 GB
#   moondream          ~1.7 GB
#
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_CHAT_MODEL=gpt-oss:120b-cloud
OLLAMA_EMBED_MODEL=nomic-embed-text
# OLLAMA_VISION_MODEL=llava:7b


# ── Ollama sampling parameters ─────────────────────────────────────────────
#
# OLLAMA_TEMPERATURE   Creativity level  (0.0 = deterministic, 1.0 = most creative)
#   gpt-oss:120b-cloud → 0.8  (large model; balanced creativity + coherence)
#   gemma4:* models    → 1.0  (Google's official recommendation)
#   gemma3:* models    → 0.7  (safe default for smaller/older models)
#
# OLLAMA_TOP_P         Nucleus sampling cut-off  (leave blank = Ollama default ~0.9)
#   gpt-oss:*          → 0.95
#   gemma4:*           → 0.95  (Google's official recommendation)
#
# OLLAMA_TOP_K         Top-K sampling  (leave blank = Ollama default)
#   gpt-oss:*          → 40
#   gemma4:*           → 64    (Google's official recommendation)
#
# OLLAMA_NUM_CTX       Context window size in tokens
#   Must be ≤ the model's hard maximum (see table below).
#   Larger = more existing chapter text + richer memory context fed to the model.
#   Cloud models have no local VRAM constraint — use the full 128K window.
#
# OLLAMA_NUM_PREDICT   Maximum tokens generated per request
#   ~750 words per 1 000 tokens.  8 192 ≈ a full long chapter in one pass.
#
# OLLAMA_REPEAT_LAST_N   Tokens scanned backward for repetition detection
#   512 covers multi-paragraph loops (Ollama default 64 is too short for chapters).
#
# OLLAMA_REPEAT_PENALTY  >1.0 discourages repeating recent tokens
#   gpt-oss:120b  → 1.05  (120B models have excellent built-in loop avoidance)
#   gemma4:*      → 1.10
#   gemma3:*      → 1.18  (older/smaller models need stronger suppression)
#
OLLAMA_TEMPERATURE=0.8
OLLAMA_TOP_P=0.95
OLLAMA_TOP_K=40
OLLAMA_NUM_CTX=131072
OLLAMA_NUM_PREDICT=8192
OLLAMA_REPEAT_LAST_N=512
OLLAMA_REPEAT_PENALTY=1.05


# ── Context budgets ─────────────────────────────────────────────────────────
#
# These cap how many tokens of each section are included in every prompt.
# All writers, editors, QA, Draft AI, and Chat Writer read these values.
#
# CONTEXT_RAG_BUDGET    Codex + beats + notes + research chunks from memory
# CONTEXT_STYLE_BUDGET  Style reference sample chunks
# CONTEXT_TEXT_BUDGET   Existing chapter draft text (for continuation / context)
#
# Scale all three together with OLLAMA_NUM_CTX using this formula:
#   input_budget  =  NUM_CTX  −  NUM_PREDICT  −  1000  (prompt overhead)
#   RAG_BUDGET    ≈  input_budget × 0.40
#   STYLE_BUDGET  ≈  input_budget × 0.15
#   TEXT_BUDGET   ≈  input_budget × 0.35
#   (remaining ≈ 0.10 reserved for beats block, editor note, QA note, persona)
#
#
# ┌──────────────────────────────────────────────────────────────────────────────┐
# │  GPT-OSS 120B CLOUD — CONFIGURATION TIERS                                    │
# │  (cloud model — no local VRAM constraint; use highest tier freely)           │
# ├────────────────────┬──────────┬─────────────┬──────────────────────────────┤
# │ Tier / Use case    │ NUM_CTX  │ NUM_PREDICT │ RAG / STYLE / TEXT           │
# ├────────────────────┼──────────┼─────────────┼──────────────────────────────┤
# │ Tier 1 — Standard  │  32 768  │    8 192    │  9000 /  3500 /  8000        │
# │ Tier 2 — Extended  │  65 536  │    8 192    │ 22000 /  8000 / 19000        │
# │ Tier 3 — Full 128K │ 131 072  │    8 192    │ 48000 / 18000 / 42000  ← ✓  │
# └────────────────────┴──────────┴─────────────┴──────────────────────────────┘
#
# Tier 3 is the recommended default for gpt-oss:120b-cloud:
#   Full 128K context window.
#   Feeds ~48 000 tokens of codex/notes — entire codex for most novels.
#   Feeds ~42 000 tokens of chapter text — multiple full chapters as context.
#   Style reference carries ~18 000 tokens of author voice examples.
#
#
# ── Tier 3 — Full 128K  (active — recommended for cloud models) ─────────────
CONTEXT_RAG_BUDGET=48000
CONTEXT_STYLE_BUDGET=18000
CONTEXT_TEXT_BUDGET=42000
#
# CONTEXT_CODEX_THRESHOLD  (cosine distance, 0.0 – 1.0)
#   In "Write from Beats" mode, codex chunks are retrieved separately and
#   filtered by their cosine distance to the beats query.
#   Keeps large codex files from wasting tokens on unrelated world-building.
#
#   ┌─────────────────────────────────────────────────────────────────────────┐
#   │ Value │ Behaviour                                                        │
#   ├───────┼──────────────────────────────────────────────────────────────────┤
#   │ 0.35  │ Very strict — only chunks that closely match a named             │
#   │       │ character/place mentioned in the beats                           │
#   │ 0.50  │ Moderate — relevant details in, noise out  ← recommended        │
#   │ 0.65  │ Permissive — lets in most of the codex; useful for short beats   │
#   │ 1.00  │ Off — no filtering (original behaviour)                          │
#   └─────────────────────────────────────────────────────────────────────────┘
#
CONTEXT_CODEX_THRESHOLD=0.50
#
# ── Tier 1 — Standard 32K  (uncomment these 5 lines, comment out Tier 3) ────
# OLLAMA_NUM_CTX=32768
# OLLAMA_NUM_PREDICT=8192
# CONTEXT_RAG_BUDGET=9000
# CONTEXT_STYLE_BUDGET=3500
# CONTEXT_TEXT_BUDGET=8000
#
# ── Tier 2 — Extended 64K  (uncomment these 5 lines, comment out Tier 3) ────
# OLLAMA_NUM_CTX=65536
# OLLAMA_NUM_PREDICT=8192
# CONTEXT_RAG_BUDGET=22000
# CONTEXT_STYLE_BUDGET=8000
# CONTEXT_TEXT_BUDGET=19000
#
#
# ── Local model settings (8 GB VRAM — Gemma 4 e2b) ───────────────────────────
# Switch to a local model:
# OLLAMA_CHAT_MODEL=gemma4:e2b
# OLLAMA_TEMPERATURE=1.0
# OLLAMA_TOP_P=0.95
# OLLAMA_TOP_K=64
# OLLAMA_NUM_CTX=32768
# OLLAMA_NUM_PREDICT=8192
# OLLAMA_REPEAT_PENALTY=1.10
# CONTEXT_RAG_BUDGET=9000
# CONTEXT_STYLE_BUDGET=3500
# CONTEXT_TEXT_BUDGET=8000
#
# ── Local model settings (legacy gemma3:4b — 8K context) ─────────────────────
# OLLAMA_CHAT_MODEL=gemma3:4b
# OLLAMA_TEMPERATURE=0.7
# OLLAMA_TOP_P=
# OLLAMA_TOP_K=
# OLLAMA_NUM_CTX=8192
# OLLAMA_NUM_PREDICT=4096
# OLLAMA_REPEAT_PENALTY=1.18
# CONTEXT_RAG_BUDGET=3500
# CONTEXT_STYLE_BUDGET=1500
# CONTEXT_TEXT_BUDGET=3000


# ══════════════════════════════════════════════════════════════════════════════
# OPENAI  (https://platform.openai.com)
# ══════════════════════════════════════════════════════════════════════════════
#
# Set LLM_PROVIDER=openai to activate.
# API key: https://platform.openai.com/api-keys
#
# CHAT MODELS
#   gpt-4.1             Most capable, best for long-form creative writing  ← recommended
#   gpt-4.1-mini        Fast & cheap, solid quality
#   gpt-4o              Previous flagship, still excellent
#   gpt-4o-mini         Budget option, good quality
#   o4-mini             Reasoning model — great for QA and editor roles
#   o3                  Most capable reasoning model
#
# EMBED MODELS
#   text-embedding-3-small   Fast & cheap  ← recommended
#   text-embedding-3-large   Higher quality, higher cost
#
# OPENAI_BASE_URL  leave blank for official OpenAI endpoint.
#   Set to a custom URL to use any OpenAI-compatible API:
#   LM Studio, vLLM, Together AI, Groq, Fireworks, Mistral, …
#
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4.1
OPENAI_EMBED_MODEL=text-embedding-3-small
OPENAI_BASE_URL=
# OPENAI_TEMPERATURE=0.8
# OPENAI_MAX_TOKENS=8192


# ══════════════════════════════════════════════════════════════════════════════
# ANTHROPIC  (https://www.anthropic.com)
# ══════════════════════════════════════════════════════════════════════════════
#
# Set LLM_PROVIDER=anthropic to activate.
# API key: https://console.anthropic.com
# Note: Anthropic has no embeddings API — keep EMBEDDINGS_PROVIDER=ollama.
#
# CHAT MODELS
#   claude-3-5-haiku-20241022    Fast & cheap, good for drafts
#   claude-3-7-sonnet-20250219   Balanced — strong creative writing  ← recommended
#   claude-opus-4-5              Most capable, highest cost
#
ANTHROPIC_API_KEY=
ANTHROPIC_CHAT_MODEL=claude-3-7-sonnet-20250219
# ANTHROPIC_TEMPERATURE=0.8
# ANTHROPIC_MAX_TOKENS=8192


# ══════════════════════════════════════════════════════════════════════════════
# GOOGLE GEMINI  (https://ai.google.dev)
# ══════════════════════════════════════════════════════════════════════════════
#
# Set LLM_PROVIDER=gemini to activate.
# API key: https://aistudio.google.com/app/apikey
# Note: Gemini embeddings not yet integrated — keep EMBEDDINGS_PROVIDER=ollama.
#
# CHAT MODELS
#   gemini-2.0-flash      Fast, cheap, excellent quality  ← recommended
#   gemini-2.5-flash      Next-gen flash, improved reasoning
#   gemini-2.5-pro        Most capable Gemini model
#   gemini-1.5-flash      Previous generation fast model (legacy)
#
GEMINI_API_KEY=
GEMINI_CHAT_MODEL=gemini-2.0-flash
# GEMINI_TEMPERATURE=0.8
# GEMINI_MAX_TOKENS=8192
